---
import { FOOTER_LINKS, SITE } from "../lib/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)] bg-[var(--color-paper)]">
	<div class="mx-auto max-w-5xl px-6 py-10">
		<div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
			<div>
				<p class="font-serif text-base text-[var(--color-text)]">{SITE.name}</p>
				<p class="mt-1 text-sm text-[var(--color-faint)]">
					Sites web et SEO local — {SITE.city} et région
				</p>
			</div>

			<nav aria-label="Liens secondaires">
				<ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[var(--color-muted)]">
					{FOOTER_LINKS.map((link) => (
						<li>
							<a href={link.href} class="hover:text-[var(--color-forest)] transition-colors">
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</nav>
		</div>

		<div class="mt-8 flex flex-col gap-1 border-t border-[var(--color-line)] pt-6 text-xs text-[var(--color-faint)] sm:flex-row sm:items-center sm:justify-between">
			<p>© {year} {SITE.name}. Tous droits réservés.</p>
			<p>
				{/* [MENTIONS LÉGALES À AJOUTER] */}
				<a href="/mentions-legales" class="hover:text-[var(--color-forest)]">Mentions légales</a>
			</p>
		</div>
	</div>
</footer>
