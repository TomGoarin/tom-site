---
const benefits = [
	{
		title: "Trouvé dans votre ville",
		body:
			"Référencement local soigné dès la mise en ligne. Vos clients vous trouvent quand ils cherchent un professionnel près d'eux.",
	},
	{
		title: "Chargé en moins de 2 secondes",
		body:
			"Pas de thème WordPress lourd, pas de scripts inutiles. Un site qui s'affiche instantanément, même sur 4G.",
	},
	{
		title: "Pas un template Wix",
		body:
			"Un design conçu pour votre activité, pas un modèle vendu cent fois. Lisible, professionnel, durable.",
	},
];
---

<section id="approche" class="border-b border-[var(--color-line)]">
	<div class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
		<h2 class="font-serif text-2xl font-medium tracking-tight text-[var(--color-text)] sm:text-3xl">
			Ce que vous obtenez
		</h2>
		<div class="mt-1 h-px w-12 bg-[var(--color-forest)]" aria-hidden="true"></div>

		<ul class="mt-12 grid gap-10 sm:grid-cols-3">
			{benefits.map((item) => (
				<li>
					<p class="font-serif text-xl font-medium text-[var(--color-ink)]">{item.title}</p>
					<p class="mt-3 text-base leading-relaxed text-[var(--color-muted)]">{item.body}</p>
				</li>
			))}
		</ul>
	</div>
</section>
