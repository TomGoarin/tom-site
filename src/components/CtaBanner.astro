---
import Button from "./Button.astro";

interface Props {
	title?: string;
	subtitle?: string;
	ctaLabel?: string;
	ctaHref?: string;
}

const {
	title = "Prêt à être trouvé sur Google ?",
	subtitle = "On en discute en 20 minutes, sans engagement.",
	ctaLabel = "Me contacter",
	ctaHref = "/contact",
} = Astro.props;
---

<section class="bg-[var(--color-ink)] text-[var(--color-paper)]">
	<div
		class="mx-auto flex max-w-5xl flex-col gap-8 px-6 py-20 sm:flex-row sm:items-center sm:justify-between sm:py-24"
	>
		<div class="max-w-xl">
			<h2 class="font-serif text-3xl font-medium tracking-tight sm:text-4xl">{title}</h2>
			<p class="mt-3 text-base text-[var(--color-paper)]/75 sm:text-lg">{subtitle}</p>
		</div>

		<Button href={ctaHref} variant="ghost-light">{ctaLabel}</Button>
	</div>
</section>
