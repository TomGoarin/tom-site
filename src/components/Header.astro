---
import { NAV_LINKS } from "../lib/site";
import Button from "./Button.astro";
---

<header
	class="sticky top-0 z-40 border-b border-[var(--color-line)] bg-[var(--color-paper)]/85 backdrop-blur-md"
>
	<div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
		<a
			href="/"
			class="font-serif text-lg font-medium tracking-tight text-[var(--color-text)] hover:text-[var(--color-forest)]"
			aria-label="Accueil — Tom Goarin"
		>
			Tom Goarin
		</a>

		<nav aria-label="Navigation principale" class="flex items-center gap-1 sm:gap-2">
			<ul class="hidden items-center gap-6 md:flex">
				{NAV_LINKS.map((link) => (
					<li>
						<a
							href={link.href}
							class="text-sm text-[var(--color-muted)] hover:text-[var(--color-forest)] transition-colors"
						>
							{link.label}
						</a>
					</li>
				))}
			</ul>

			<Button href="/contact" variant="primary" class="ml-4">
				Me contacter
			</Button>
		</nav>
	</div>
</header>
